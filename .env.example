# ─────────────────────────────────────────────────────────────
#  Client env (build-time, read by Vite)
#  These are the PUBLIC Supabase anon/publishable values — safe to
#  ship in the client bundle. Copy this file to `.env` and fill in.
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# ─────────────────────────────────────────────────────────────
#  Backend secrets — DO NOT put these here or in client env.
#  Set them as Supabase Edge Function secrets
#  (Dashboard → Project Settings → Edge Functions → Secrets).
#  Listed here for reference only.
# ─────────────────────────────────────────────────────────────
#
#  AI provider (any OpenAI-compatible Chat Completions API):
#    AI_API_KEY   = sk-...                      (required for AI features)
#    AI_BASE_URL  = https://api.openai.com/v1   (optional; this is the default)
#    AI_MODEL     = gpt-4o-mini                 (optional; this is the default)
#
#  Supabase service role (auto-injected into Edge Functions by Supabase):
#    SUPABASE_URL
#    SUPABASE_SERVICE_ROLE_KEY
